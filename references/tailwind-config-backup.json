{
  "theme": {
    "extend": {
      "colors": {
        "tech": {
          "primary": "#00ffcc",
          "secondary": "#0099ff",
          "accent": "#cc00ff",
          "dark": "#0a0a0f",
          "light": "#1a1a2e"
        },
        "cyberpunk": {
          "primary": "#ff00ff",
          "secondary": "#00ffff",
          "accent": "#ffff00",
          "dark": "#000000",
          "light": "#330033"
        },
        "neon": {
          "primary": "#00ff88",
          "secondary": "#ff0088",
          "accent": "#8800ff",
          "dark": "#000022",
          "light": "#220044"
        }
      },
      "fontFamily": {
        "sans": ["'Inter'", "'PingFang SC'", "'Microsoft YaHei'", "sans-serif"],
        "mono": ["'JetBrains Mono'", "'Menlo'", "'Monaco'", "'Courier New'", "monospace"],
        "display": ["'SF Pro Display'", "'PingFang SC'", "sans-serif"]
      },
      "backgroundImage": {
        "gradient-tech": "linear-gradient(45deg, #00ffcc, #0099ff, #cc00ff)",
        "gradient-cyberpunk": "linear-gradient(45deg, #ff00ff, #00ffff, #ffff00)",
        "gradient-neon": "linear-gradient(45deg, #00ff88, #ff0088, #8800ff)",
        "gradient-dark": "linear-gradient(135deg, #0a0a0f 0%, #1a1a2e 100%)"
      },
      "animation": {
        "float": "float 3s ease-in-out infinite",
        "pulse-glow": "pulse-glow 2s ease-in-out infinite",
        "slide-in": "slide-in 0.6s ease-out",
        "fade-in": "fade-in 0.8s ease-out"
      },
      "keyframes": {
        "float": {
          "0%, 100%": { transform: "translateY(0px)" },
          "50%": { transform: "translateY(-10px)" }
        },
        "pulse-glow": {
          "0%, 100%": { opacity: "1", filter: "brightness(1)" },
          "50%": { opacity: "0.8", filter: "brightness(1.3)" }
        },
        "slide-in": {
          "from": { transform: "translateY(20px)", opacity: "0" },
          "to": { transform: "translateY(0)", opacity: "1" }
        },
        "fade-in": {
          "from": { opacity: "0" },
          "to": { opacity: "1" }
        }
      }
    }
  },
  "plugins": [],
  "content": ["./src/**/*.{html,js,ts,jsx,tsx}"],
  "darkMode": "class",
  "important": true
}